{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/genaptic/skillsets/main/schemas/eval-report.schema.json",
  "title": "Structural evaluation export",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "skills", "totals"],
  "properties": {
    "schemaVersion": {"const": 1},
    "skills": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/skillReport"}
    },
    "totals": {
      "type": "object",
      "additionalProperties": false,
      "required": ["skills", "routingCases", "behaviorCases"],
      "properties": {
        "skills": {"type": "integer", "minimum": 1},
        "routingCases": {"type": "integer", "minimum": 1},
        "behaviorCases": {"type": "integer", "minimum": 1}
      }
    }
  },
  "$defs": {
    "skillReport": {
      "type": "object",
      "additionalProperties": false,
      "required": ["skill", "routingCases", "behaviorCases", "routing", "behavior"],
      "properties": {
        "skill": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "routingCases": {"type": "integer", "minimum": 7},
        "behaviorCases": {"type": "integer", "minimum": 2},
        "routing": {
          "type": "array",
          "minItems": 7,
          "items": {"$ref": "#/$defs/routingCase"}
        },
        "behavior": {
          "type": "array",
          "minItems": 2,
          "items": {"$ref": "#/$defs/behaviorCase"}
        }
      }
    },
    "routingCase": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "prompt", "shouldTrigger", "reason"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "kind": {
          "enum": [
            "explicit-positive",
            "implicit-positive",
            "contextual-positive",
            "negative",
            "overlap"
          ]
        },
        "prompt": {"type": "string", "minLength": 20},
        "shouldTrigger": {"type": "boolean"},
        "preferredSkill": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "reason": {"type": "string", "minLength": 20}
      }
    },
    "behaviorCase": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "prompt", "assertions", "forbidden"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "kind": {"enum": ["focused", "end-to-end", "error-handling", "safety"]},
        "prompt": {"type": "string", "minLength": 30},
        "assertions": {
          "type": "array",
          "minItems": 3,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 10}
        },
        "forbidden": {
          "type": "array",
          "minItems": 2,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 10}
        }
      }
    }
  }
}
