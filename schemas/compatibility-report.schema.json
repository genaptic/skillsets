{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/genaptic/skillsets/main/schemas/compatibility-report.schema.json",
  "title": "Native client compatibility report",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "testedAt", "client", "pack", "environment", "installation", "cases", "effects", "reviewer", "verdict"],
  "properties": {
    "schemaVersion": {"const": 2},
    "testedAt": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-(?:0[1-9]|1[0-2])-(?:0[1-9]|[12][0-9]|3[01])T(?:[01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]Z$"
    },
    "client": {
      "type": "object", "additionalProperties": false, "required": ["name", "version", "model"],
      "properties": {
        "name": {"enum": ["claude-code", "codex", "opencode"]},
        "version": {"type": "string", "minLength": 1},
        "model": {"type": "string", "minLength": 1}
      }
    },
    "pack": {
      "type": "object", "additionalProperties": false, "required": ["id", "version", "tag", "sourceSha", "expectedSkills"],
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
        "version": {"type": "string", "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-(?:0|[1-9][0-9]*|[0-9]*[A-Za-z-][0-9A-Za-z-]*)(?:\\.(?:0|[1-9][0-9]*|[0-9]*[A-Za-z-][0-9A-Za-z-]*))*)?(?:\\+[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?$"},
        "tag": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*-v(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-(?:0|[1-9][0-9]*|[0-9]*[A-Za-z-][0-9A-Za-z-]*)(?:\\.(?:0|[1-9][0-9]*|[0-9]*[A-Za-z-][0-9A-Za-z-]*))*)?(?:\\+[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?$"},
        "sourceSha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
        "expectedSkills": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}}
      }
    },
    "environment": {
      "type": "object", "additionalProperties": false, "required": ["operatingSystem", "shell"],
      "properties": {"operatingSystem": {"type": "string", "minLength": 1}, "shell": {"type": ["string", "null"]}}
    },
    "installation": {
      "type": "object", "additionalProperties": false, "required": ["method", "discoveredSkills", "permissions"],
      "properties": {
        "method": {"type": "string", "minLength": 1},
        "discoveredSkills": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
        "permissions": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}
      }
    },
    "cases": {
      "type": "object", "additionalProperties": false, "required": ["routing", "behavior", "boundaries"],
      "properties": {
        "routing": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/case"}},
        "behavior": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/case"}},
        "boundaries": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/boundaryCase"}}
      }
    },
    "effects": {
      "type": "object", "additionalProperties": false, "required": ["network", "filesystem"],
      "properties": {"network": {"type": "array", "items": {"type": "string"}}, "filesystem": {"type": "array", "items": {"type": "string"}}}
    },
    "reviewer": {
      "type": "object", "additionalProperties": false, "required": ["github", "githubId", "verdict"],
      "properties": {
        "github": {"type": "string", "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9-]{0,37}[A-Za-z0-9])?$", "maxLength": 39},
        "githubId": {"type": "integer", "minimum": 1},
        "verdict": {"enum": ["passed", "failed"]}
      }
    },
    "verdict": {
      "type": "object", "additionalProperties": false, "required": ["status", "notes"],
      "properties": {"status": {"enum": ["passed", "failed"]}, "notes": {"type": "string"}}
    }
  },
  "$defs": {
    "case": {
      "type": "object", "additionalProperties": false, "required": ["skill", "id", "passed", "notes"],
      "properties": {"skill": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"}, "id": {"type": "string", "minLength": 1}, "passed": {"type": "boolean"}, "notes": {"type": "string"}}
    },
    "boundaryCase": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "boundaryId",
        "caseId",
        "scope",
        "boundarySkills",
        "installedPacks",
        "expectedSkills",
        "observedSkills",
        "passed",
        "notes"
      ],
      "properties": {
        "boundaryId": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "caseId": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "scope": {
          "description": "Whether both boundary skills share one owning pack or require a multi-pack run.",
          "enum": ["internal-pack", "cross-pack"]
        },
        "boundarySkills": {
          "description": "The exact canonical sorted skill pair made available for this boundary run.",
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"}
        },
        "installedPacks": {
          "description": "The exact sorted owning pack IDs installed for this boundary run.",
          "type": "array",
          "minItems": 1,
          "maxItems": 2,
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"}
        },
        "expectedSkills": {
          "type": "array",
          "maxItems": 2,
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"}
        },
        "observedSkills": {
          "type": "array",
          "maxItems": 2,
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"}
        },
        "passed": {"type": "boolean"},
        "notes": {"type": "string"}
      }
    }
  }
}
