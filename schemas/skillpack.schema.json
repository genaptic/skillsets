{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/genaptic/skillsets/main/schemas/skillpack.schema.json",
  "title": "Genaptic Skillpack manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema-version",
    "id",
    "display-name",
    "description",
    "language",
    "subject",
    "version",
    "maturity",
    "distribution",
    "publication",
    "release-gates",
    "interface",
    "license",
    "maintainers",
    "skills",
    "targets",
    "category",
    "keywords",
    "compatibility",
    "operations"
  ],
  "properties": {
    "schema-version": {"const": 2},
    "id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$", "maxLength": 64},
    "display-name": {"type": "string", "minLength": 3, "maxLength": 80},
    "description": {"type": "string", "minLength": 40, "maxLength": 500},
    "language": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$", "maxLength": 32},
    "subject": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$", "maxLength": 48},
    "version": {"$ref": "#/$defs/semantic-version"},
    "maturity": {"enum": ["draft", "release-candidate", "stable", "deprecated"]},
    "distribution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["visibility"],
      "properties": {
        "visibility": {"enum": ["public", "maintainers"]}
      }
    },
    "publication": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state"],
      "properties": {
        "state": {"enum": ["unpublished", "published", "withdrawn"]},
        "latest-release": {"$ref": "#/$defs/latest-release"}
      },
      "allOf": [
        {
          "if": {"properties": {"state": {"const": "unpublished"}}, "required": ["state"]},
          "then": {"not": {"required": ["latest-release"]}}
        },
        {
          "if": {"properties": {"state": {"enum": ["published", "withdrawn"]}}, "required": ["state"]},
          "then": {"required": ["latest-release"]}
        }
      ]
    },
    "release-gates": {
      "type": "array",
      "uniqueItems": true,
      "items": {"enum": ["native-evidence", "deterministic-archive", "rust-assets"]}
    },
    "interface": {
      "type": "object",
      "additionalProperties": false,
      "required": ["short-description", "starter-prompts"],
      "properties": {
        "short-description": {
          "type": "string",
          "minLength": 25,
          "maxLength": 120,
          "pattern": "^\\S(?:.*[.!?])$"
        },
        "starter-prompts": {
          "type": "array",
          "minItems": 2,
          "maxItems": 4,
          "uniqueItems": true,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["skill", "prompt"],
            "properties": {
              "skill": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$", "maxLength": 64},
              "prompt": {"type": "string", "minLength": 30, "maxLength": 300, "pattern": "^\\S(?:.*\\S)?$"}
            }
          }
        }
      }
    },
    "license": {"type": "string", "minLength": 3, "maxLength": 64},
    "maintainers": {
      "type": "array", "minItems": 1, "uniqueItems": true,
      "items": {"type": "object", "additionalProperties": false, "required": ["github"], "properties": {"github": {"type": "string", "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9-]{0,37}[A-Za-z0-9])?$"}}}
    },
    "skills": {"type": "array", "minItems": 1, "maxItems": 20, "uniqueItems": true, "items": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$", "maxLength": 64}},
    "targets": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"enum": ["claude-code", "codex", "opencode"]}},
    "category": {"type": "string", "minLength": 3, "maxLength": 40},
    "keywords": {"type": "array", "minItems": 3, "maxItems": 12, "uniqueItems": true, "items": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$", "maxLength": 32}},
    "compatibility": {
      "type": "object", "additionalProperties": false, "required": ["runtimes", "notes"],
      "properties": {
        "runtimes": {"type": "object", "minProperties": 1, "propertyNames": {"pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"}, "additionalProperties": {"type": "string", "minLength": 1, "maxLength": 100}},
        "notes": {"type": "string", "minLength": 20, "maxLength": 500}
      }
    },
    "operations": {
      "type": "object", "additionalProperties": false, "required": ["network", "filesystem", "command-execution", "external-writes"],
      "properties": {
        "network": {"enum": ["none", "optional", "required"]},
        "filesystem": {"enum": ["read-only", "explicit-output", "project-write", "system-write"]},
        "command-execution": {"enum": ["none", "optional-explicit", "required"]},
        "external-writes": {"enum": ["none", "optional-explicit", "required"]}
      }
    }
  },
  "$defs": {
    "semantic-version": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-(?:0|[1-9][0-9]*|[0-9]*[A-Za-z-][0-9A-Za-z-]*)(?:\\.(?:0|[1-9][0-9]*|[0-9]*[A-Za-z-][0-9A-Za-z-]*))*)?(?:\\+[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?$"
    },
    "latest-release": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "source-sha", "release-id", "released-at"],
      "properties": {
        "version": {"$ref": "#/$defs/semantic-version"},
        "source-sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
        "release-id": {"type": "integer", "minimum": 1},
        "released-at": {
          "type": "string",
          "format": "date-time",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
        }
      }
    }
  },
  "allOf": [
    {
      "if": {"properties": {"language": {"const": "rust"}}, "required": ["language"]},
      "then": {"properties": {"release-gates": {"const": ["native-evidence", "deterministic-archive", "rust-assets"]}}},
      "else": {"properties": {"release-gates": {"const": ["native-evidence", "deterministic-archive"]}}}
    },
    {
      "if": {"properties": {"distribution": {"properties": {"visibility": {"const": "maintainers"}}, "required": ["visibility"]}}, "required": ["distribution"]},
      "then": {"properties": {"publication": {"properties": {"state": {"const": "unpublished"}}, "required": ["state"]}}}
    }
  ]
}
