{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/genaptic/skillsets/main/schemas/compatibility-evidence-envelope.schema.json",
  "title": "Protected native compatibility evidence envelope",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "repository", "workflow", "source", "evidence", "client", "packId", "testedAt"],
  "properties": {
    "schemaVersion": {"const": 1},
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "slug"],
      "properties": {
        "id": {"type": "integer", "minimum": 1},
        "slug": {"type": "string", "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$", "maxLength": 140}
      }
    },
    "workflow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["runId", "runAttempt", "workflowRef", "workflowSha", "event", "actor", "triggeringActor"],
      "properties": {
        "runId": {"type": "integer", "minimum": 1},
        "runAttempt": {"type": "integer", "minimum": 1},
        "workflowRef": {"type": "string", "minLength": 1, "maxLength": 500},
        "workflowSha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
        "event": {"const": "workflow_dispatch"},
        "actor": {"$ref": "#/$defs/githubIdentity"},
        "triggeringActor": {"$ref": "#/$defs/githubIdentity"}
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sha"],
      "properties": {"sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"}}
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["commitSha", "reportPath", "reportSha256"],
      "properties": {
        "commitSha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
        "reportPath": {"type": "string", "pattern": "^compatibility/reports/(?!.*(?:^|/)\\.\\.?/)[A-Za-z0-9._/-]+\\.json$", "maxLength": 500},
        "reportSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    },
    "client": {"enum": ["claude-code", "codex", "opencode"]},
    "packId": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "testedAt": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-(?:0[1-9]|1[0-2])-(?:0[1-9]|[12][0-9]|3[01])T(?:[01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]Z$"
    }
  },
  "$defs": {
    "githubIdentity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["github", "githubId"],
      "properties": {
        "github": {"type": "string", "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9-]{0,37}[A-Za-z0-9])?$", "maxLength": 39},
        "githubId": {"type": "integer", "minimum": 1}
      }
    }
  }
}
