{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/genaptic/skillsets/main/schemas/generated-files.schema.json",
  "title": "Generated file integrity manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "files"],
  "properties": {
    "schemaVersion": {"const": 1},
    "files": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "sha256", "size", "mode"],
        "properties": {
          "path": {"type": "string", "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9._/-]+$"},
          "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "size": {"type": "integer", "minimum": 0},
          "mode": {"enum": ["0644", "0755"]}
        }
      }
    }
  }
}
