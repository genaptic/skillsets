{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/genaptic/skillsets/main/schemas/publication-record.schema.json",
  "title": "Immutable release publication record",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "repository", "packId", "version", "releaseId", "tag", "url", "sourceSha", "baseCommit", "publishedAt", "immutable", "draft", "prerelease"],
  "properties": {
    "schemaVersion": {"const": 1},
    "repository": {"type": "string", "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"},
    "packId": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "version": {"type": "string", "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-(?:0|[1-9][0-9]*|[0-9]*[A-Za-z-][0-9A-Za-z-]*)(?:\\.(?:0|[1-9][0-9]*|[0-9]*[A-Za-z-][0-9A-Za-z-]*))*)?(?:\\+[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?$"},
    "releaseId": {"type": "integer", "minimum": 1},
    "tag": {"type": "string", "minLength": 1},
    "url": {"type": "string", "format": "uri", "pattern": "^https://github\\.com/"},
    "sourceSha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "baseCommit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "publishedAt": {"type": "string", "format": "date-time", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"},
    "immutable": {"const": true},
    "draft": {"const": false},
    "prerelease": {"const": false}
  }
}
