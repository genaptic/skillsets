{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/genaptic/skillsets/main/packs/shared/repository-development/skills/create-new-skill/assets/skill-request.schema.json",
  "title": "Create New Skill request",
  "description": "Resolved input for creating exactly one Agent Skill in an existing Genaptic skillpack.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "skillName",
    "packId",
    "expectedPackVersion",
    "details",
    "scope",
    "expectedOutput",
    "successCriteria",
    "examples",
    "nearestNeighbor",
    "constraints",
    "operations",
    "sourceRequirements",
    "openai"
  ],
  "properties": {
    "schemaVersion": {"const": 1},
    "skillName": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "maxLength": 64,
      "description": "Resolved globally unique public skill name; proposed normalization must be approved before this request is written."
    },
    "packId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "maxLength": 64,
      "description": "Existing skillpack that owns the new skill."
    },
    "expectedPackVersion": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$",
      "description": "Current manifest version used as a stale-request precondition."
    },
    "details": {
      "type": "string",
      "minLength": 40,
      "maxLength": 12000
    },
    "scope": {"$ref": "#/$defs/scope"},
    "expectedOutput": {
      "type": "string",
      "minLength": 20,
      "maxLength": 3000
    },
    "successCriteria": {
      "type": "array",
      "minItems": 2,
      "maxItems": 20,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 10, "maxLength": 1000}
    },
    "examples": {"$ref": "#/$defs/examples"},
    "nearestNeighbor": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "maxLength": 64,
      "description": "Existing public skill that owns the closest excluded outcome."
    },
    "constraints": {
      "type": "array",
      "minItems": 1,
      "maxItems": 20,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 3, "maxLength": 1000}
    },
    "operations": {"$ref": "#/$defs/operations"},
    "sourceRequirements": {"$ref": "#/$defs/sourceRequirements"},
    "openai": {"$ref": "#/$defs/openai"},
    "userSources": {"$ref": "#/$defs/httpSources"}
  },
  "$defs": {
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["useWhen", "doNotUseWhen", "supportedEnvironments"],
      "properties": {
        "useWhen": {
          "type": "array",
          "minItems": 2,
          "maxItems": 20,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 10, "maxLength": 1000}
        },
        "doNotUseWhen": {
          "type": "array",
          "minItems": 2,
          "maxItems": 20,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 10, "maxLength": 1000}
        },
        "supportedEnvironments": {
          "type": "array",
          "minItems": 1,
          "maxItems": 20,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 3, "maxLength": 500}
        }
      }
    },
    "examples": {
      "type": "object",
      "additionalProperties": false,
      "required": ["shouldTrigger", "shouldNotTrigger"],
      "properties": {
        "shouldTrigger": {
          "type": "array",
          "minItems": 2,
          "maxItems": 20,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 20, "maxLength": 2000}
        },
        "shouldNotTrigger": {
          "type": "array",
          "minItems": 2,
          "maxItems": 20,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 20, "maxLength": 2000}
        }
      }
    },
    "operations": {
      "type": "object",
      "additionalProperties": false,
      "required": ["network", "filesystem", "commandExecution", "externalWrites"],
      "properties": {
        "network": {"enum": ["none", "optional", "required"]},
        "filesystem": {"enum": ["read-only", "explicit-output", "project-write", "system-write"]},
        "commandExecution": {"enum": ["none", "optional-explicit", "required"]},
        "externalWrites": {"enum": ["none", "optional-explicit", "required"]}
      }
    },
    "sourceRequirements": {
      "type": "object",
      "additionalProperties": false,
      "required": ["freshness", "requiredAuthorities"],
      "properties": {
        "freshness": {"type": "string", "minLength": 10, "maxLength": 1000},
        "requiredAuthorities": {
          "type": "array",
          "minItems": 1,
          "maxItems": 12,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 3, "maxLength": 300}
        }
      }
    },
    "openai": {
      "type": "object",
      "additionalProperties": false,
      "required": ["displayName", "shortDescription", "defaultPrompt"],
      "properties": {
        "displayName": {"type": "string", "minLength": 3, "maxLength": 80},
        "shortDescription": {"type": "string", "minLength": 25, "maxLength": 64},
        "defaultPrompt": {
          "type": "string",
          "minLength": 20,
          "maxLength": 300,
          "pattern": "\\$[a-z0-9]+(?:-[a-z0-9]+)*"
        }
      }
    },
    "httpSources": {
      "type": "array",
      "maxItems": 20,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "format": "uri",
        "pattern": "^https?://(?![^/?#]*@)[^\\s]+$"
      }
    }
  }
}
